{
  "manifest_version": 2,
  "name": "JAM",
  "version": "1.0",
  "key": "",
  "description": "Script automation engine with session management, referrer and visibility spoofing.",

  "permissions": [
    "tabs",
    "storage",
    "clipboardWrite",
    "clipboardRead",
    "webRequest",
    "webRequestBlocking",
    "activeTab",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },

  "options_page": "options/options.html",

  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },

  "web_accessible_resources": ["bridge.js", "engine/*.js"]
}