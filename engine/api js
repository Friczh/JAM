(function () {
  'use strict';

  window._jam_rid = 0;
  window._jam_pending = {};

  window.addEventListener('message', (event) => {
    if (event.source !== window) return;
    if (!event.data || event.data.origin !== 'jam_content') return;

    const { requestId, response, type, enabled } = event.data;

    if (type === 'INIT_VISIBILITY') {
      if (enabled) window.scriptengine.visibility.spoof(true);
      return;
    }

    if (_jam_pending[requestId]) {
      _jam_pending[requestId](response);
      delete _jam_pending[requestId];
    }
  });

  function _send(msg) {
    return new Promise((resolve) => {
      const requestId = ++window._jam_rid;
      window._jam_pending[requestId] = resolve;
      window.postMessage({ ...msg, origin: 'jam_bridge', requestId }, '*');
    });
  }

  window.scriptengine = {
    _send,

    session: {},
    storage: {},
    clipboard: {},
    visibility: {},
    referrer: {},
    paste: {},

    submit(selector) {
      const el = document.querySelector(selector);
      if (!el) return false;
      el.dispatchEvent(new MouseEvent('click', { bubbles: true }));
      return true;
    }
  };
})();